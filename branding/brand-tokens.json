{
  "meta": {
    "brand": "VinylFort",
    "version": "1.0.0",
    "description": "Design tokens for VinylFort — copy these values into style.css :root or your design tool."
  },
  "color": {
    "surface":        { "value": "#0e0c0b", "usage": "Page / app background" },
    "surface-light":  { "value": "#1a1613", "usage": "Card / panel background" },
    "border":         { "value": "#2e2924", "usage": "Dividers, card borders" },
    "primary":        { "value": "#c8973f", "usage": "Primary buttons, links, brand accent" },
    "secondary":      { "value": "#8a6e52", "usage": "Secondary actions, muted accents" },
    "accent":         { "value": "#e8c06a", "usage": "Highlights, badges, active states" },
    "success":        { "value": "#4ade80", "usage": "Success states, positive indicators" },
    "danger":         { "value": "#ef4444", "usage": "Errors, destructive actions" },
    "text":           { "value": "#f5ede2", "usage": "Primary body text" },
    "text-muted":     { "value": "#c8b19c", "usage": "Secondary / helper text" },
    "overlay":        { "value": "rgba(0,0,0,0.85)", "usage": "Modal backdrop" }
  },
  "typography": {
    "fontFamily": {
      "sans":  { "value": "'Inter', system-ui, sans-serif",               "usage": "UI, body, labels" },
      "serif": { "value": "'Cormorant Garamond', Georgia, serif",          "usage": "Display headings, hero text" },
      "mono":  { "value": "ui-monospace, 'Cascadia Code', monospace",      "usage": "Token IDs, code snippets" }
    },
    "fontSize": {
      "xs":  "0.75rem",
      "sm":  "0.875rem",
      "md":  "1rem",
      "lg":  "1.125rem",
      "xl":  "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem"
    },
    "fontWeight": {
      "normal":    400,
      "medium":    500,
      "semibold":  600,
      "bold":      700,
      "extrabold": 800
    }
  },
  "spacing": {
    "xs":  "0.25rem",
    "sm":  "0.5rem",
    "md":  "0.75rem",
    "lg":  "1rem",
    "xl":  "1.5rem",
    "2xl": "2rem",
    "3xl": "3rem"
  },
  "borderRadius": {
    "sm": "0.5rem",
    "md": "0.75rem",
    "lg": "1rem",
    "xl": "1.5rem",
    "full": "9999px"
  },
  "shadow": {
    "gold-glow":   "0 0 20px rgba(200,151,63,0.3)",
    "purple-glow": "0 0 40px rgba(124,58,237,0.2)",
    "card":        "0 4px 24px rgba(0,0,0,0.4)"
  },
  "pwa": {
    "themeColor":      "#c8973f",
    "backgroundColor": "#0e0c0b"
  }
}
