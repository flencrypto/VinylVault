<?xml version="1.0" encoding="utf-8"?>
<!-- VinylVault splash screen — centered vinyl record logo on dark background -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <item>
        <color android:color="#0E0C0B" />
    </item>
    <!-- Centered vinyl record icon (128dp × 128dp) -->
    <item
        android:width="128dp"
        android:height="128dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#C8973F" />
        </shape>
    </item>
</layer-list>
