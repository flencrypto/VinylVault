#!/bin/sh
# Gradle wrapper script for VinylVault Android project
# Generated for Gradle 8.6

##############################################################################
# Gradle start up script for POSIX generated by "Gradle init"
##############################################################################

APP_HOME=$(cd "$(dirname "$0")" && pwd -P) || exit
APP_NAME="Gradle"
APP_BASE_NAME="${0##*/}"

DEFAULT_JVM_OPTS='"-Xmx2g" "-Xms512m"'

CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

exec java \
  "-classpath" "$CLASSPATH" \
  "-Dorg.gradle.appname=$APP_BASE_NAME" \
  $DEFAULT_JVM_OPTS \
  org.gradle.wrapper.GradleWrapperMain \
  "$@"
